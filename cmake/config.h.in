/* config.h - Generated by CMake for ThorVG */

#ifndef _THORVG_CONFIG_H_
#define _THORVG_CONFIG_H_

#define THORVG_VERSION_STRING "@PROJECT_VERSION@"

/* Multi-Tasking */
#cmakedefine THORVG_THREAD_SUPPORT 1

/* Engines */
#cmakedefine THORVG_SW_RASTER_SUPPORT 1
#cmakedefine THORVG_GL_RASTER_SUPPORT 1
#cmakedefine THORVG_WG_RASTER_SUPPORT 1

/* Partial Rendering */
#cmakedefine THORVG_PARTIAL_RENDER_SUPPORT 1

/* Loaders */
#cmakedefine THORVG_SVG_LOADER_SUPPORT 1
#cmakedefine THORVG_PNG_LOADER_SUPPORT 1
#cmakedefine THORVG_JPG_LOADER_SUPPORT 1
#cmakedefine THORVG_LOTTIE_LOADER_SUPPORT 1
#cmakedefine THORVG_TTF_LOADER_SUPPORT 1
#cmakedefine THORVG_WEBP_LOADER_SUPPORT 1

/* Savers */
#cmakedefine THORVG_GIF_SAVER_SUPPORT 1

/* Vectorization */
#cmakedefine THORVG_AVX_VECTOR_SUPPORT 1
#cmakedefine THORVG_NEON_VECTOR_SUPPORT 1

/* Bindings */
#cmakedefine THORVG_CAPI_BINDING_SUPPORT 1

/* Log */
#cmakedefine THORVG_LOG_ENABLED 1

/* File IO */
#cmakedefine THORVG_FILE_IO_SUPPORT 1

/* Extra */
#cmakedefine THORVG_LOTTIE_EXPRESSIONS_SUPPORT 1
#cmakedefine THORVG_OPENMP_SUPPORT 1

/* Miscellaneous */
#define WIN32_LEAN_AND_MEAN 1

#endif /* _THORVG_CONFIG_H_ */
